generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(uuid())
  name       String?
  email      String   @unique
  password   String
  role       String   @default("RESPONSAVEL")
  created_at DateTime @default(now())

  obras      Obra[]
}

model Client {
  id              String       @id  @default(uuid())

  name            String
  email           String?
  phone           String?
  cpf             String?

  createdAt       DateTime     @default(now())

  obras           Obra[]
}

model Obra {
  id                String   @id @default(uuid())
  code              String   @unique
  name              String 
  status            String

//Localização 
  state             String
  city              String
  address           String

//Datas
  startDate         DateTime
  expectedEndDate   DateTime
  actualEndDate     DateTime?

//Financeiro
  budget            Decimal
  totalSpent        Decimal   @default(0)
  
  budgetItems       BudgetItem[]

//Cliente
  clientId         String
  client           Client    @relation(fields: [clientId], references: [id])

// Timestamps
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  userId            String
  user              User      @relation(fields: [userId], references: [id])  

  expenses          Expense[]
}


model Expense {

  id               String   @id @default(uuid())

  obraId           String

  obra             Obra @relation(fields: [obraId], references: [id])

  budgetItemId     String?

  budgetItem       BudgetItem? @relation(fields: [budgetItemId], references: [id])

  description      String
  category         String
  quantity         Float?
  unitPrice        Decimal?
  totalPaid        Decimal
  supplier         String?

  date             DateTime
  createdAt        DateTime @default(now())
}


model BudgetItem {
  id              String @id @default(uuid())

  obraId          String
  obra            Obra @relation(fields: [obraId], references: [id])

  description     String
  unit            String

  quantity        Float
  unitPrice       Decimal

  expenses        Expense[]

  createdAt       DateTime @default(now())
}